# PRISM — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# Gemini (Google AI Studio) — Required
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# LangSmith Tracing — Optional but recommended for observability
# Get your key at https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=prism-analyst

# App Config
PRISM_ENV=development
EXPORT_DIR=/tmp/prism_exports
